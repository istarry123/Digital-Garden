# ---- Site ----
# Your production domain (used in RSS, sitemap, OG tags)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# ---- Image CDN (optional) ----
# Accelerate images via CDN. Leave empty to serve from local /assets/images/.
# Example: https://cdn.example.com
NEXT_PUBLIC_IMAGE_CDN=

# ---- Giscus Comments (optional) ----
# Get IDs from https://giscus.app after enabling Discussions on your repo
NEXT_PUBLIC_GISCUS_REPO=your-username/your-repo
NEXT_PUBLIC_GISCUS_REPO_ID=R_kgDOGXXXXX
NEXT_PUBLIC_GISCUS_CATEGORY=General
NEXT_PUBLIC_GISCUS_CATEGORY_ID=DIC_kwDOGXXXXX

# ---- Analytics (optional, enable in blog.config.ts) ----
# Umami — privacy-first analytics
# NEXT_PUBLIC_UMAMI_ID=your-umami-website-id
#
# Google Analytics 4
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
#
# 51la 网站统计
# NEXT_PUBLIC_51LA_ID=your-51la-id
# NEXT_PUBLIC_51LA_CK=your-51la-ck
#
# 百度统计
# NEXT_PUBLIC_BAIDU_TONGJI_ID=your-baidu-tongji-id
#
# Microsoft Clarity
# NEXT_PUBLIC_CLARITY_ID=your-clarity-project-id
